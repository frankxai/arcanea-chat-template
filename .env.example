# ─────────────────────────────────────────────────────────────────────────
# Arcanea Chat Template — BYOK-first. Zero required vars for basic demo.
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED for auth/session persistence.
# Generate: openssl rand -base64 32  (or https://generate-secret.vercel.app/32)
AUTH_SECRET=

# ─────────────────────────────────────────────────────────────────────────
# BYOK MODE (recommended for Arcanea deployments)
# ─────────────────────────────────────────────────────────────────────────
# Users paste their own API keys in the settings panel. Keys stay in
# localStorage on their machine, flow through x-byok-* headers at request
# time, and are NEVER stored in your database or logs.
#
# In BYOK mode, you do NOT need to set AI_GATEWAY_API_KEY below.

# ─────────────────────────────────────────────────────────────────────────
# FALLBACK: Vercel AI Gateway (if you want server-paid inference)
# ─────────────────────────────────────────────────────────────────────────
# Only needed if users don't bring their own keys.
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# PERSISTENCE (optional — without these the template runs in guest mode)
# ─────────────────────────────────────────────────────────────────────────
# https://vercel.com/docs/postgres
POSTGRES_URL=

# https://vercel.com/docs/redis  (for resumable streams)
REDIS_URL=

# https://vercel.com/docs/vercel-blob  (for file uploads in artifacts)
BLOB_READ_WRITE_TOKEN=
